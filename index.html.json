{
  "index.html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover\" />\n    <title>NaldoA Play | Official App</title>\n    \n    <link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Montserrat:wght@300;400;600;900&display=swap\" rel=\"stylesheet\">\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n\n    <style>\n        :root {\n            --primary: #d4af37;\n            --bg-glass: rgba(0, 0, 0, 0.85);\n            --text-color: #ffffff;\n            --accent-glow: rgba(212, 175, 55, 0.4);\n        }\n\n        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }\n        \n        body { \n            background: #000; color: var(--text-color); \n            font-family: 'Montserrat', sans-serif; \n            height: 100vh; width: 100vw; overflow: hidden; display: flex;\n        }\n\n        #master-bg {\n            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;\n            background-size: cover; background-position: center; filter: brightness(0.4);\n            transition: 1s ease; background-image: url('https://images.unsplash.com/photo-1464802686167-b939a67e06a1');\n        }\n\n        /* SIDEBAR */\n        aside {\n            width: 280px; background: var(--bg-glass); backdrop-filter: blur(30px);\n            border-right: 1px solid rgba(255,255,255,0.1);\n            display: flex; flex-direction: column; padding: 40px 20px; z-index: 1000;\n        }\n\n        .nav-menu { display: flex; flex-direction: column; gap: 10px; flex: 1; }\n        .nav-item {\n            background: none; border: 1px solid transparent; color: inherit;\n            padding: 15px; border-radius: 15px; display: flex; align-items: center; gap: 12px;\n            font-family: 'Orbitron'; font-size: 0.7rem; cursor: pointer; transition: 0.3s;\n            text-decoration: none;\n        }\n        .nav-item.active { background: var(--primary); color: #000 !important; font-weight: 900; box-shadow: 0 10px 20px var(--accent-glow); }\n\n        /* AREA DE CONTEÚDO */\n        main { flex: 1; height: 100vh; position: relative; overflow-y: auto; scroll-behavior: smooth; }\n        .view { display: none; padding: 30px; animation: fadeIn 0.5s ease; width: 100%; }\n        .view.active { display: flex; flex-direction: column; }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; } }\n\n        /* HOME HUB COMPLETO */\n        .home-grid { display: grid; grid-template-columns: 350px 1fr; gap: 30px; align-items: start; max-width: 1200px; margin: 0 auto; }\n        .hero-img { width: 100%; border-radius: 30px; border: 4px solid var(--primary); box-shadow: 0 0 30px var(--accent-glow); }\n        .hero-info h1 { font-family: 'Orbitron'; font-size: 3.5rem; color: var(--primary); line-height: 1; margin-bottom: 15px; }\n        \n        .extra-desc { margin-top: 20px; line-height: 1.6; font-size: 0.9rem; color: rgba(255,255,255,0.7); border-left: 2px solid var(--primary); padding-left: 15px; }\n\n        .links-wall { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; margin-top: 25px; }\n        .link-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 15px; text-align: center; text-decoration: none; color: inherit; transition: 0.3s; display: flex; flex-direction: column; align-items: center; gap: 8px; }\n        .link-card:hover { background: var(--primary); color: #000; transform: translateY(-5px); }\n        .link-card span { font-family: 'Orbitron'; font-size: 0.55rem; font-weight: 700; }\n\n        /* PLAYER COM ESPECTRO */\n        .radio-container { position: relative; width: 280px; height: 280px; margin: 0 auto 30px; display: flex; align-items: center; justify-content: center; }\n        .spectrum-ring {\n            position: absolute; width: 100%; height: 100%;\n            border: 4px solid var(--primary); border-radius: 50%;\n            animation: pulse-ring 2s infinite cubic-bezier(0.455, 0.03, 0.515, 0.955);\n            box-shadow: 0 0 30px var(--accent-glow);\n            animation-play-state: paused;\n        }\n        @keyframes pulse-ring { 0% { transform: scale(0.9); opacity: 0.8; } 50% { transform: scale(1.1); opacity: 0.4; border-width: 10px; } 100% { transform: scale(0.9); opacity: 0.8; } }\n        .radio-logo-main { width: 220px; height: 220px; border-radius: 50%; object-fit: cover; z-index: 2; border: 4px solid #fff; }\n        \n        .play-btn-vivo {\n            width: 90px; height: 90px; border-radius: 50%; background: var(--primary); border: none; \n            margin: 0 auto; cursor: pointer; display: flex; align-items: center; justify-content: center;\n            box-shadow: 0 0 40px var(--accent-glow); transition: 0.3s;\n        }\n\n        /* VÍDEOS BORDAS LUXO */\n        .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; width: 100%; }\n        .video-box { \n            background: #000; border-radius: 25px; overflow: hidden; \n            border: 3px solid rgba(255,255,255,0.1); aspect-ratio: 16/9; \n            transition: 0.4s; position: relative;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n        }\n        .video-box:hover { border-color: var(--primary); transform: scale(1.03); box-shadow: 0 15px 40px var(--accent-glow); }\n        .video-box iframe { width: 100%; height: 100%; border: none; }\n\n        /* MEGA CATÁLOGO DE TEMAS */\n        .catalog-section { margin-top: 20px; }\n        .catalog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 15px; margin-bottom: 30px; }\n        .theme-opt { cursor: pointer; text-align: center; background: rgba(255,255,255,0.05); padding: 12px; border-radius: 15px; border: 1px solid transparent; transition: 0.2s; }\n        .theme-opt:hover { border-color: var(--primary); transform: translateY(-5px); }\n        .theme-opt .box { width: 100%; height: 60px; border-radius: 10px; margin-bottom: 8px; background-size: cover; background-position: center; }\n\n        /* PALETA DE CORES */\n        .palette { display: flex; flex-wrap: wrap; gap: 12px; }\n        .color-dot { width: 45px; height: 45px; border-radius: 50%; border: 3px solid #fff; cursor: pointer; transition: 0.3s; }\n        .color-dot:hover { transform: scale(1.2); }\n\n        .footer-nav { margin: 50px 0 20px; text-align: center; opacity: 0.5; font-size: 0.7rem; letter-spacing: 4px; font-family: 'Orbitron'; color: var(--primary); }\n\n        @media (max-width: 900px) {\n            body { flex-direction: column; }\n            aside { width: 100%; height: auto; position: fixed; bottom: 0; top: auto; flex-direction: row; padding: 10px; border-top: 1px solid var(--primary); border-right: none; }\n            .nav-menu { flex-direction: row; justify-content: space-around; width: 100%; }\n            .nav-item { flex-direction: column; font-size: 0.5rem; padding: 8px; border: none; gap: 5px; }\n            .hide-mobile { display: none; }\n            main { height: calc(100vh - 70px); }\n            .home-grid { grid-template-columns: 1fr; text-align: center; }\n            .hero-img { width: 150px; margin: 0 auto; }\n            .hero-info h1 { font-size: 2.2rem; }\n        }\n    </style>\n</head>\n<body>\n\n    <div id=\"master-bg\"></div>\n\n    <aside>\n        <div class=\"hide-mobile\" style=\"text-align:center; margin-bottom:40px;\">\n            <h2 style=\"font-family:'Orbitron'; color:var(--primary); letter-spacing:5px;\">NALDOA</h2>\n            <p style=\"font-size:0.5rem; opacity:0.8; letter-spacing: 2px;\">NALDOA PLAY</p>\n        </div>\n        <nav class=\"nav-menu\">\n            <button class=\"nav-item active\" onclick=\"tab('home', this)\"><i data-lucide=\"user\"></i> HOME</button>\n            <button class=\"nav-item\" onclick=\"tab('radio', this)\"><i data-lucide=\"radio\"></i> RÁDIO</button>\n            <button class=\"nav-item\" onclick=\"tab('videos', this)\"><i data-lucide=\"play-circle\"></i> VÍDEOS</button>\n            <button class=\"nav-item\" onclick=\"tab('config', this)\"><i data-lucide=\"palette\"></i> TEMAS</button>\n        </nav>\n    </aside>\n\n    <main id=\"scroller\">\n        <!-- HOME: TODOS OS LINKS + DESCRIÇÃO NOVA -->\n        <section id=\"home\" class=\"view active\">\n            <div class=\"home-grid\">\n                <img src=\"images/logo.jpg\" class=\"hero-img\">\n                <div class=\"hero-info\">\n                    <h1>NALDOA<span>.</span></h1>\n                    <p style=\"opacity:0.9; font-weight: 600; font-size: 0.9rem; margin-bottom: 10px; color: var(--primary);\">DJ, Produtor de EDM & Trance</p>\n                    \n                    <div class=\"extra-desc\">\n                        Explore o ecossistema oficial <b>NaldoA Play</b>. Aqui você encontra a fusão perfeita entre batidas Progressivas e a energia do Trance. Navegue pelos nossos canais oficiais, acompanhe lançamentos globais e mergulhe em uma experiência visual e sonora exclusiva feita para quem vive a música eletrônica intensamente.\n                    </div>\n\n                    <div class=\"links-wall\">\n                        <a href=\"https://open.spotify.com/artist/05anJA6CE7Afkn0hYyVMRV\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"music\"></i><span>SPOTIFY</span></a>\n                        <a href=\"https://youtube.com/@djnaldoaoficial\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"youtube\"></i><span>YOUTUBE</span></a>\n                        <a href=\"https://music.apple.com/br/artist/naldoa/1782398892\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"apple\"></i><span>APPLE</span></a>\n                        <a href=\"https://www.soundon.global/bio/naldoa\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"share-2\"></i><span>SOUNDON</span></a>\n                        <a href=\"https://music.amazon.com.br/artists/B0DP59T244/naldoa\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"headphones\"></i><span>AMAZON</span></a>\n                        <a href=\"https://deezer.page.link/x7uW8uBfUuX\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"mic-2\"></i><span>DEEZER</span></a>\n                        <a href=\"https://instagram.com/naldoaoficial\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"instagram\"></i><span>INSTAGRAM</span></a>\n                        <a href=\"https://github.com/naldoaplay\" target=\"_blank\" class=\"link-card\"><i data-lucide=\"github\"></i><span>GITHUB</span></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"footer-nav\">NALDOA PLAY © 2026</div>\n        </section>\n\n        <!-- RÁDIO: ESPECTRO -->\n        <section id=\"radio\" class=\"view\">\n            <div style=\"text-align: center; max-width: 600px; margin: auto;\">\n                <div class=\"radio-container\">\n                    <div class=\"spectrum-ring\" id=\"ring\"></div>\n                    <img src=\"images/logo.jpg\" class=\"radio-logo-main\">\n                </div>\n                <h2 style=\"font-family:'Orbitron'; color:var(--primary); font-size: 2.2rem;\">NALDOA PLAY</h2>\n                <p style=\"font-family:'Orbitron'; font-size:0.7rem; letter-spacing:8px; margin-bottom:30px; opacity:0.6;\">SINTONIZADO AO VIVO</p>\n                <button onclick=\"toggleAudio()\" class=\"play-btn-vivo\">\n                    <i data-lucide=\"play\" id=\"p-icon\" style=\"width:45px; height:45px; fill:#000; color:#000;\"></i>\n                </button>\n                <input type=\"range\" oninput=\"setVol(this.value)\" min=\"0\" max=\"1\" step=\"0.01\" style=\"width:100%; max-width:350px; margin-top:40px; accent-color:var(--primary);\">\n            </div>\n            <div class=\"footer-nav\">NALDOA PLAY | RÁDIO</div>\n        </section>\n\n        <!-- VÍDEOS: GRADE COMPLETA VOLTOU -->\n        <section id=\"videos\" class=\"view\">\n            <h2 style=\"font-family:'Orbitron'; margin-bottom:30px; color:var(--primary);\">DISCOGRAFIA VISUAL</h2>\n            <div class=\"video-grid\">\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/YwQkLOX8m0E\"></iframe></div>\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/sQeY8CwXQ9w\"></iframe></div>\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/3RpVyPb96sU\"></iframe></div>\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/zKaXDl5Texk\"></iframe></div>\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/mcx2w71PANE\"></iframe></div>\n                <div class=\"video-box\"><iframe src=\"https://www.youtube.com/embed/aZHefqVqXpU\"></iframe></div>\n            </div>\n            <div class=\"footer-nav\">CONTEÚDO OFICIAL NALDOA</div>\n        </section>\n\n        <!-- TEMAS: CATÁLOGO MASSIVO VOLTOU -->\n        <section id=\"config\" class=\"view\">\n            <h2 style=\"font-family:'Orbitron'; color:var(--primary); margin-bottom:30px;\">SUPER CATÁLOGO DE TEMAS</h2>\n            \n            <div class=\"catalog-section\">\n                <p style=\"font-family:'Orbitron'; font-size:0.7rem; opacity:0.5; margin-bottom:15px;\">IMAGENS E CENÁRIOS</p>\n                <div class=\"catalog-grid\">\n                    <div class=\"theme-opt\" onclick=\"setT('https://images.unsplash.com/photo-1464802686167-b939a67e06a1', 'dark')\"><div class=\"box\" style=\"background-image:url('https://images.unsplash.com/photo-1464802686167-b939a67e06a1')\"></div><span>UNIVERSO</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('https://images.unsplash.com/photo-1441974231531-c6227db76b6e', 'light')\"><div class=\"box\" style=\"background-image:url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e')\"></div><span>FLORESTA</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('https://images.unsplash.com/photo-1470225620780-dba8ba36b745', 'dark')\"><div class=\"box\" style=\"background-image:url('https://images.unsplash.com/photo-1470225620780-dba8ba36b745')\"></div><span>STUDIO</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('https://images.unsplash.com/photo-1514525253361-b83f859b73c0', 'dark')\"><div class=\"box\" style=\"background-image:url('https://images.unsplash.com/photo-1514525253361-b83f859b73c0')\"></div><span>NIGHT CLUB</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('https://images.unsplash.com/photo-1550684848-fac1c5b4e853', 'dark')\"><div class=\"box\" style=\"background-image:url('https://images.unsplash.com/photo-1550684848-fac1c5b4e853')\"></div><span>CYBERPUNK</span></div>\n                </div>\n\n                <p style=\"font-family:'Orbitron'; font-size:0.7rem; opacity:0.5; margin-bottom:15px; margin-top:20px;\">GRADIENTES VIVOS</p>\n                <div class=\"catalog-grid\">\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #00f2fe, #4facfe)', 'light', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #00f2fe, #4facfe)\"></div><span>CYAN WAVE</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #ee0979, #ff6a00)', 'dark', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #ee0979, #ff6a00)\"></div><span>NEON FIRE</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #8e2de2, #4a00e0)', 'dark', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #8e2de2, #4a00e0)\"></div><span>PURPLE RAIN</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #ff9a9e, #fad0c4)', 'light', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #ff9a9e, #fad0c4)\"></div><span>PASTEL SUN</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #232526, #414345)', 'dark', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #232526, #414345)\"></div><span>PURE ONYX</span></div>\n                    <div class=\"theme-opt\" onclick=\"setT('linear-gradient(45deg, #11998e, #38ef7d)', 'light', true)\"><div class=\"box\" style=\"background:linear-gradient(45deg, #11998e, #38ef7d)\"></div><span>LIME FRESH</span></div>\n                </div>\n\n                <p style=\"font-family:'Orbitron'; font-size:0.7rem; opacity:0.5; margin-bottom:15px; margin-top:20px;\">PALETA DE ACENTO</p>\n                <div class=\"palette\">\n                    <button class=\"color-dot\" style=\"background:#d4af37\" onclick=\"setC('#d4af37')\"></button>\n                    <button class=\"color-dot\" style=\"background:#00f2fe\" onclick=\"setC('#00f2fe')\"></button>\n                    <button class=\"color-dot\" style=\"background:#ff0055\" onclick=\"setC('#ff0055')\"></button>\n                    <button class=\"color-dot\" style=\"background:#00ff00\" onclick=\"setC('#00ff00')\"></button>\n                    <button class=\"color-dot\" style=\"background:#ffffff\" onclick=\"setC('#ffffff')\"></button>\n                    <button class=\"color-dot\" style=\"background:#9d00ff\" onclick=\"setC('#9d00ff')\"></button>\n                    <button class=\"color-dot\" style=\"background:#ff6a00\" onclick=\"setC('#ff6a00')\"></button>\n                    <button class=\"color-dot\" style=\"background:#000000\" onclick=\"setC('#000000')\"></button>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    <audio id=\"core\"></audio>\n\n    <script>\n        lucide.createIcons();\n        const audio = document.getElementById('core');\n        const ring = document.getElementById('ring');\n        const streamUrl = \"https://stream.zeno.fm/s49f874w3vduv\";\n\n        function tab(id, btn) {\n            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));\n            document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));\n            document.getElementById(id).classList.add('active');\n            btn.classList.add('active');\n            lucide.createIcons();\n        }\n\n        function toggleAudio() {\n            if(audio.paused || audio.src === \"\") { \n                audio.src = streamUrl; // Garante que pegue o stream fresco\n                audio.play(); \n                document.getElementById('p-icon').setAttribute('data-lucide', 'pause');\n                ring.style.animationPlayState = 'running';\n            } else { \n                audio.pause(); \n                audio.src = \"\"; // Reseta o source para não ficar baixando dados à toa\n                document.getElementById('p-icon').setAttribute('data-lucide', 'play');\n                ring.style.animationPlayState = 'paused';\n            }\n            lucide.createIcons();\n        }\n\n        function setVol(v) { audio.volume = v; }\n\n        function setT(src, mode, isGrad = false) {\n            const bg = document.getElementById('master-bg');\n            bg.style.backgroundImage = isGrad ? src : `url('${src}')`;\n            if(mode === 'light') {\n                document.documentElement.style.setProperty('--text-color', '#000');\n                document.documentElement.style.setProperty('--bg-glass', 'rgba(255,255,255,0.85)');\n            } else {\n                document.documentElement.style.setProperty('--text-color', '#fff');\n                document.documentElement.style.setProperty('--bg-glass', 'rgba(0,0,0,0.85)');\n            }\n        }\n\n        function setC(c) {\n            document.documentElement.style.setProperty('--primary', c);\n            document.documentElement.style.setProperty('--accent-glow', c + '66');\n        }\n    </script>\n</body>\n</html>\n"
}